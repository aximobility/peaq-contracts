# peaq-contracts environment template
# Copy to .env and fill in. NEVER commit .env.

# ---- RPC endpoints ----
PEAQ_RPC_HTTP_AGUNG=https://peaq-agung.api.onfinality.io/public
PEAQ_RPC_HTTP_MAINNET=https://peaq-rpc.publicnode.com

# ---- Deploy signer (NOT the operational signer; deploy-only) ----
DEPLOYER_PRIVATE_KEY=0x

# ---- Operational role recipients (granted at constructor / init) ----
# Comma-separated EVM addresses. Each role gets its own slot.
ISSUERS=0x
ATTESTORS=0x
APPROVERS=0x
ADMIN=0x

# ---- Block explorer verification (optional) ----
PEAQ_AGUNG_VERIFIER_KEY=
PEAQ_MAINNET_VERIFIER_KEY=
